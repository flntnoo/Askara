generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  title             String?
  description       String
  shortDescription  String?
  category          String
  cardCount         Int      @default(0)
  estimatedMinutes  Int
  estimatedDuration String?
  suitableFor       String[] @default([])
  topics            String[] @default([])
  isPremium         Boolean  @default(false)
  isRecommended     Boolean  @default(false)
  colorVariant      String   @default("primary")
  color             String?
  icon              String?
  coverIllustration String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cards    Card[]
  sessions Session[]

  @@index([category, isActive])
  @@index([sortOrder])
}

model Card {
  id          String   @id @default(cuid())
  deckId      String
  type        String   @default("question")
  topic       String
  sensitivity String   @default("low")
  phase       String
  content     String
  isPremium   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deck           Deck            @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sessionActions SessionAction[]
  favorites      Favorite[]

  @@index([deckId])
  @@index([deckId, isActive, phase, sortOrder])
}

model User {
  id          String   @id @default(cuid())
  anonymousId String?  @unique
  email       String?  @unique
  name        String?
  provider    String   @default("anonymous")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  onboarding      OnboardingPreference?
  sessions        Session[]
  favorites       Favorite[]
  analyticsEvents AnalyticsEvent[]

  @@index([provider])
}

model OnboardingPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  relationshipType    String?
  relationshipStage   String?
  preferredTone       String?
  completedOnboarding Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  deckId        String
  status        String   @default("active")
  currentCardId String?
  startedAt     DateTime @default(now())
  endedAt       DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck    Deck            @relation(fields: [deckId], references: [id])
  actions SessionAction[]

  @@index([userId, status])
  @@index([deckId])
  @@index([startedAt])
}

model SessionAction {
  id        String   @id @default(cuid())
  sessionId String
  cardId    String
  action    String
  shownAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id])

  @@index([sessionId])
  @@index([sessionId, action])
  @@index([cardId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  payload   Json?
  timestamp DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, timestamp])
  @@index([userId])
  @@index([timestamp])
}
